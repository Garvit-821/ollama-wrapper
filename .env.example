# VISION AI Assistant - Environment Variables
# Copy this file to .env and fill in your values

# Ollama base URL (Optional - defaults to local Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model (Optional - defaults to phi3:mini)
OLLAMA_MODEL=phi3:mini

# Weather API (Optional - uses wttr.in if not set)
OPENWEATHER_API_KEY=

# Email Configuration (Optional)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Brave Browser Path (Optional - auto-detected if not set)
BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe

# City for weather (Optional)
WEATHER_CITY=Delhi
